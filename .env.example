# Root env for `docker compose` variable interpolation only (NOT an app env file
# — the backend/frontend read their own backend/.env and frontend/.env).
#
# Copy to `.env`. Only the frontend's build-time public Clerk key is needed here,
# because Docker bakes NEXT_PUBLIC_* into the build. Everything else is loaded
# from backend/.env and frontend/.env via compose `env_file`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
