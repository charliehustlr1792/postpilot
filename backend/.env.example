# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Clerk (backend) ────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Clerk Dashboard → Webhooks → your endpoint → Signing Secret (starts with whsec_)
CLERK_WEBHOOK_SECRET=whsec_xxx

# ── Database (PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (BullMQ queue) ───────────────────────────────
# Upstash/Railway provide a rediss:// URL; ioredis negotiates TLS from the scheme.
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379

# ── CORS ───────────────────────────────────────────────
# The frontend origin allowed to call this API.
FRONTEND_URL=http://localhost:3000

# ── OAuth & token encryption ───────────────────────────
# OAuth redirect URIs are built from FRONTEND_URL (the callback is proxied under
# the frontend origin), so no separate backend public URL is needed here.
# 32-byte hex keys. Generate each with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars
OAUTH_STATE_SECRET=replace-with-64-hex-chars

# Social platform OAuth credentials (from each provider's developer portal).
# Leave a platform blank to disable its connect flow.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── Media storage (Cloudinary) ─────────────────────────
# From the Cloudinary console dashboard. Leave blank to disable uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ─────────────────────────────────────
# Team invite emails. Leave RESEND_API_KEY blank to skip sending (records still
# created). EMAIL_FROM needs a verified domain in prod; onboarding@resend.dev
# works in test mode.
RESEND_API_KEY=
EMAIL_FROM=PostPilot <onboarding@resend.dev>
