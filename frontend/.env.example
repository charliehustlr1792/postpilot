# ── Clerk (frontend) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── Backend API ────────────────────────────────────────
# The frontend proxies /api/* to the backend (see next.config.ts), so the
# browser talks to the backend same-origin. Point this at the backend address.
BACKEND_INTERNAL_URL=http://localhost:5000
# Optional: set to bypass the proxy and call the backend directly (not same-origin).
# NEXT_PUBLIC_API_URL=

# ── Builder.io (optional) ──────────────────────────────
NEXT_PUBLIC_BUILDER_API_KEY=
